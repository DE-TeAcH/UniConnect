{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "api/hello.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/hello", "dest": "/api/hello.js" },
    { "src": "/api/ping", "dest": "/api/index.ts?category=ping" },
    { "src": "/api/([^/]+)/([^/]+)", "dest": "/api/index.ts?category=$1&action=$2" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}